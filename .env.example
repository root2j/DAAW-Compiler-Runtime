# DAAW Compiler-Runtime — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Cloud LLM Providers (set whichever you have) ──
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Local LLM via Ollama / LM Studio / vLLM ──
# Ollama: http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
GATEWAY_URL=http://localhost:11434/v1
GATEWAY_TOKEN=
GATEWAY_MODEL=gemma4:e2b-it-q4_K_M   # e2b is reliable on planner JSON; e4b is not

# Ollama-specific (ignored by LM Studio / vLLM / other backends):
# Context window hint. Ollama's OpenAI-compat endpoint defaults to 2048,
# which overflows any workflow with tool results — bump this if you see
# "Gateway produced degenerate (empty) output" errors.
# GATEWAY_NUM_CTX=8192
# How long Ollama keeps the model resident between requests. Reduces
# VRAM fragmentation churn on sequential calls.
# GATEWAY_KEEP_ALIVE=5m

# Max characters per dependency output fed to a downstream task.
# Default 2000 is fine for cloud models; drop to 500 for small local
# models (gemma4:e4b/e2b, qwen:3b) that drift into degenerate output on
# large prompts.
# DAAW_MAX_DEP_CHARS=500

# ── Webhook Notifications (optional) ──
# NOTIFY_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook
# NOTIFY_WEBHOOK_TYPE=discord
# Types: discord, slack, generic

# ── API Rate Limits (per-provider) ──
# Per-provider sliding-window request/min cap and optional token budget.
# Empty / unset = use sensible defaults (see src/daaw/llm/rate_limiter.py).
# Set to 0 to explicitly disable a cap.

# Requests per minute — default: groq=28, gemini=55, openai=50, anthropic=45, gateway=0
# DAAW_RPM_GROQ=28
# DAAW_RPM_GEMINI=55
# DAAW_RPM_OPENAI=50
# DAAW_RPM_ANTHROPIC=45

# Token budget per window (default: unlimited = 0). e.g. 1M tokens / day:
# DAAW_TOKEN_BUDGET_GEMINI=1000000
# DAAW_TOKEN_WINDOW_GEMINI=86400   # seconds; 86400 = 1 day

# Max seconds a single caller will queue before raising RateLimitExceeded.
# DAAW_MAX_WAIT_GROQ=120

# Global fallbacks (applied when per-provider not set):
# DAAW_RPM=30
# DAAW_TOKEN_BUDGET=0
# DAAW_TOKEN_WINDOW=86400
# DAAW_MAX_WAIT=120
