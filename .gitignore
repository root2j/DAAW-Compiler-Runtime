# Eval runner intermediates — the per-run artifact store and stdout logs
# are regenerated each run. Actual evaluation artifacts (summary,
# aggregates, by_prompt) ARE committed for reproducibility.
evals/runs/*/.artifact_store/
evals/runs/*_stdout.log
evals/runs/2*/

# OS junk
.DS_Store
Thumbs.db
